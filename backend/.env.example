# ============================================================
# .env.example — Mẫu biến môi trường hệ thống
# CHATBOT TUYỂN SINH ĐH VINH
# ============================================================
# HƯỚNG DẪN SỬ DỤNG:
#   1. Sao chép file này: cp .env.example .env
#   2. Điền giá trị thực vào .env
#   3. TUYỆT ĐỐI KHÔNG commit file .env lên git (đã có trong .gitignore)
# ============================================================

# -----------------------------------------------------------
# [1] GOOGLE GEMINI API
# -----------------------------------------------------------
# Lấy API Key tại: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSy_YOUR_ACTUAL_KEY_HERE

# Tên model Gemini — giữ nguyên flash để tối ưu chi phí & tốc độ
GEMINI_MODEL=gemini-2.5-flash

# -----------------------------------------------------------
# [2] QDRANT VECTOR DATABASE (Self-hosted qua Docker)
# -----------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Tên collection lưu trữ dữ liệu tuyển sinh ĐH Vinh
QDRANT_COLLECTION=tuyen_sinh_dhv

# API Key Qdrant (để trống nếu chạy nội bộ không xác thực)
QDRANT_API_KEY=

# -----------------------------------------------------------
# [3] REDIS SESSION STORE
# -----------------------------------------------------------
REDIS_URL=redis://localhost:6379

# Thời gian sống của một phiên chat: 1800 giây = 30 phút
SESSION_TTL_SECONDS=1800

# Database index Redis (0-15, mặc định 0)
REDIS_DB=0

# -----------------------------------------------------------
# [4] EMBEDDING MODEL (Chạy offline cục bộ)
# -----------------------------------------------------------
# Model sẽ được tải về ~/.cache/huggingface/ lần đầu chạy
EMBED_MODEL=BAAI/bge-m3

# Số chiều vector của bge-m3 — KHÔNG thay đổi giá trị này
EMBED_DIMENSION=1024

# Kích thước batch khi encode nhiều chunk cùng lúc
EMBED_BATCH_SIZE=32

# -----------------------------------------------------------
# [5] FASTAPI SERVER
# -----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# Danh sách origins được phép gọi API (phân cách bằng dấu phẩy)
# Môi trường dev: thêm http://localhost:3000
# Môi trường prod: chỉ giữ domain chính thức của trường
CORS_ORIGINS=http://localhost:3000,https://tuyensinh.vinhuni.edu.vn

# -----------------------------------------------------------
# [6] INDEXING PIPELINE
# -----------------------------------------------------------
# Thư mục tạm chứa ảnh JPEG khi xử lý PDF
TMP_IMAGE_DIR=./tmp_images

# Số trang xử lý song song (tăng nếu server nhiều CPU)
PIPELINE_WORKERS=2

# -----------------------------------------------------------
# [7] LOGGING
# -----------------------------------------------------------
# Mức độ log: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
